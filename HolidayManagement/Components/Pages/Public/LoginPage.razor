@page "/public/login"

@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using HolidayManagement.Models.Login
@using HolidayManagement.Helpers

@inject NavigationManager navigationManager
@inject Services.Interfaces.IModelService<User> userService
@inject Services.Interfaces.IModelService<UserInstitution> userInstitutionService
@inject Services.Interfaces.IModelService<Institution> institutionService
@inject Services.Interfaces.IModelService<Role> roleService

<h3>LoginPage</h3>
<EditForm Model="Model" OnSubmit="Authenticate" FormName="LoginForm">
    <div class="mb-3 text center flex-column">
        <h3>Login</h3>
    </div>
    <div class="mb-3">
        <label>Username</label>
        <InputText @bind-Value="Model.Username" class="form-control" placeholder="Username" />
        <ValidationMessage For="() => Model.Username" />
    </div>
    <div class="mb-3">
        <label>Password</label>
        <InputText @bind-Value="Model.Password" class="form-control" placeholder="Password" />
        <ValidationMessage For="() => Model.Password" />
    </div>
    <div class="mb-3">
        <label>Institution ID</label>
        <InputText @bind-Value="Model.InstitutionId" class="form-control" placeholder="Institution" />
        <ValidationMessage For="() => Model.InstitutionId" />
    </div>
    <div class="mb-3 text-center">
        <span class="text-danger">@errorMessage</span>
    </div>
    <div class="mb-3 d-grid gap-2">
        <input type="submit" value="Login" class="btn btn-primary" />
    </div>
</EditForm>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm]
    public LoginUser Model { get; set; } = new();
    private string errorMessage;

    private List<User> users;
    private List<Role> roles;
    private List<UserInstitution> userInstitutions;
    private List<Institution> institutions;

    protected override async Task OnInitializedAsync()
    {
        users = await userService.GetAll();
        roles = await roleService.GetAll();
        userInstitutions = await userInstitutionService.GetAll();
        institutions = await institutionService.GetAll();
    }
    private async Task Authenticate(EditContext context)
    {
        User u = users.FirstOrDefault(x => x.Username == Model.Username);
        if (u is null || !(new PasswordManager().Verify(Model.Password, u.Password)))
        {
            errorMessage = "Invalid Username or Password";
        }
        else
        {
            var role = userInstitutions.FirstOrDefault(x => x.UserId == u.Id && x.InstitutionId == Guid.Parse(Model.InstitutionId)).RoleId;
            var claims = new List<Claim>
            {
                new Claim("ID", u.Id+""),
                new Claim(ClaimTypes.Name, u.Username),
                new Claim(ClaimTypes.Role, roles.Single(x => x.Id == role).Name)
            };
            var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
            var principal = new ClaimsPrincipal(identity);
            await HttpContext.SignInAsync(principal);
            navigationManager.NavigateTo("/");
        }
    }

}
