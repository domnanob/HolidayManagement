@page "/users"
@rendermode InteractiveServer

@inject Services.Interfaces.IModelService<User> userService
@inject Services.Interfaces.IModelService<UserData> userDataService

<h3>UsersTestPage</h3>  

@if (_users == null)
{
    <span class="placeholder col-6"></span>
}
else
{
    @if (_users.Count == 0)
    {
        <div>No data found!</div>
        <button class="btn btn-outline-info" @onclick="CreateDummyUser">Create Dummy</button>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">Id</th>
                    <th scope="col">Username</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _users)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Username</td>
                        <td>
                            <button @onclick="() => DeleteUser(item.Id)" class="btn btn-outline-danger">Delete</button>
                            <a href="/users/update/@item.Id" class="btn btn-outline-info">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <table class="table">
            <thead>
                <tr>
                    <th scope="col">Id</th>
                    <th scope="col">Email</th>
                    <th scope="col">Phone</th>
                    <th scope="col">Birth</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _userDatas)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.Birth</td>
                        <td>
                            <button @onclick="() => DeleteUser(item.Id)" class="btn btn-outline-danger">Delete</button>
                            <a href="/users/update/@item.Id" class="btn btn-outline-info">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<Models.User> _users;
    private List<Models.UserData> _userDatas;
    protected override async Task OnInitializedAsync()
    {
        _users = await userService.GetAll() ?? new List<Models.User>();
        _userDatas = await userDataService.GetAll() ?? new List<Models.UserData>();
    }
    public async void CreateDummyUser()
    {
        Models.UserData ud = new Models.UserData()
        {
            Id = Guid.NewGuid(),
            Birth = new DateTime(),
            Children = 0,
            Email = "domnanob@gmail.com",
            Phone = "+36303627517"
        };
        await userDataService.Create(ud);
        await userService.Create(new Models.User()
        {
            Username = "Dummy",
            Password = "Password",
            DataId = ud.Id,
            RoleId = Guid.NewGuid()

        });
        _users = await userService.GetAll();
        StateHasChanged();
    }

    public async void DeleteUser(Guid id)
    {
        await userDataService.Delete(_users.Single(x => x.Id == id).DataId);
        //await userService.Delete(id); //cascade miatt nem kell
        
        _users = await userService.GetAll();
        StateHasChanged();
    }

}
